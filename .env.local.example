# Supabase — Koolacube CMS
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Dashboard → Project Settings → API). `.env.local` is gitignored.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SERVER ONLY — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
